# Telegram bot koji prima notifikacije za nove zahteve (proveru plana i prijave partnera).
# Napraviti bota preko @BotFather na Telegramu, zatim mu poslati bilo koju poruku
# i preko https://api.telegram.org/bot<TOKEN>/getUpdates pronaći svoj chat_id.
# Ove vrednosti se podešavaju u Vercel → Project → Settings → Environment Variables,
# ne pišu se u ovaj fajl niti se commit-uju.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
